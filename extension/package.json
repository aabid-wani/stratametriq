{
  "name": "stratometriq-extension",
  "displayName": "StrataMetriq",
  "description": "Architecture Intelligence & Pre-Deployment Safety in VS Code",
  "version": "1.1.0",
  "publisher": "stratometriq",
  "icon": "icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/aabid-wani/stratametriq.git"
  },
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "stratometriq.start",
        "title": "StrataMetriq: Open Dashboard"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "node copy-dist.js && esbuild ./src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node",
    "build": "npm run package"
  },
  "devDependencies": {
    "@types/vscode": "^1.80.0",
    "@types/node": "18.x",
    "typescript": "^5.3.3",
    "esbuild": "^0.19.12"
  },
  "dependencies": {
    "@stratometriq/shared": "*",
    "@stratometriq/scanner": "*"
  }

}
